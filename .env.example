# =============================================================================
# Polybot — environment template. Copy to `.env` and fill in.
# =============================================================================

# ---- mode ------------------------------------------------------------------
TRADING_MODE=paper                         # paper | live
PAPER_STARTING_USDC=10000

# ---- Polymarket endpoints --------------------------------------------------
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_DATA_URL=https://data-api.polymarket.com
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws

# ---- Polygon RPC (use a real provider in prod — public RPC is rate-limited) -
POLYGON_RPC_URL=https://polygon-rpc.com
POLYGON_CHAIN_ID=137

# ---- Goldsky subgraph (replace with your hosted endpoint id) ---------------
GOLDSKY_SUBGRAPH_URL=https://api.goldsky.com/api/public/REPLACE/subgraphs/polymarket-positions/prod/gn

# ---- Live trading creds (LEAVE EMPTY for paper-mode) -----------------------
# Legacy env-based wallet (deprecated — prefer the encrypted wallet credential
# stored in DB via the dashboard's /settings/Wallet tab; see WALLET_ENCRYPTION_KEY).
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=
POLYMARKET_SIGNATURE_TYPE=1                # 0=EOA  1=email/magic  2=browser

# ---- Wallet encryption — REQUIRED for live mode ----------------------------
# 32-byte symmetric key (base64-encoded) used to AES-256-GCM encrypt every
# signing key stored in the wallet_credentials table. WITHOUT this:
#  - the dashboard "Add wallet" button silently fails
#  - encrypted wallets in the DB cannot be decrypted (= no live trading)
#  - losing this key = losing access to every wallet stored in the DB
# Back up to your password manager AND a second offline location.
#
# Generate one with:
#   python3 -c "import secrets,base64;print(base64.b64encode(secrets.token_bytes(32)).decode())"
WALLET_ENCRYPTION_KEY=

# ---- Database --------------------------------------------------------------
POSTGRES_USER=polybot
POSTGRES_PASSWORD=change_me
POSTGRES_DB=polybot
DATABASE_URL=postgresql+psycopg://polybot:change_me@postgres:5432/polybot

# ---- Redis ----------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# ---- API & dashboard -------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
DASHBOARD_API_URL=http://localhost:8000
ADMIN_TOKEN=please-generate-a-long-random-string
# CORS origins — comma-separated, NO wildcard. Use the dashboard's exact origin.
# In prod set this to https://your-domain.com or e.g. https://polybot.example.com
CORS_ORIGINS=http://localhost:3000

# ---- Risk limits (USDC) ----------------------------------------------------
MAX_POSITION_USDC=25
MAX_DAILY_LOSS_USDC=50
MAX_OPEN_POSITIONS=5
COOLDOWN_SECONDS_PER_MARKET=300

# ---- Wallet tracking -------------------------------------------------------
TOP_WALLETS_PER_CATEGORY=30
MIN_WIN_RATE=0.55
MIN_TRADE_COUNT_30D=20
CORRELATION_WINDOW_MINUTES=15
CORRELATION_MIN_WALLETS=3
CORRELATION_MIN_SCORE=0.65

# ---- Optional integrations -------------------------------------------------
SENTRY_DSN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- Off-host DB backup to GitHub (optional) -------------------------------
# Daily pg_dump gets pushed to a private GitHub repo, so a host disk failure
# can't lose both the live DB and the backup. Leave empty to disable.
#
# Setup:
#   1. Create a private repo on GitHub, e.g. yourname/polybot-backups
#   2. Generate a personal access token with `repo` scope on that repo
#   3. Fill the two vars below
#
# Rotation keeps the N most recent dumps in the repo (default 7).
GITHUB_BACKUP_TOKEN=
GITHUB_BACKUP_REPO=
GITHUB_BACKUP_KEEP=7
GITHUB_BACKUP_BRANCH=main

# ---- SIWE (Sign-In With Ethereum) auth ----
# SECURITY-CRITICAL. Comma-separated lowercase Ethereum addresses that
# can sign in to the dashboard via wallet connection. An empty list with
# a public dashboard means anyone reaching the URL could authenticate
# and take over the bot, so the server refuses SIWE logins when this is
# empty UNLESS SIWE_DEV_MODE_ALLOW_ANY=true is also set.
# Example: ADMIN_WALLET_ADDRESSES=0xabc...,0xdef...
ADMIN_WALLET_ADDRESSES=

# Local-dev escape hatch: lets ANY wallet authenticate via SIWE when the
# allowlist is empty. Loud warning is logged on every login. NEVER
# enable this on any deployment that's reachable from the internet.
SIWE_DEV_MODE_ALLOW_ANY=false

# ---- Admin auth path ------------------------------------------------------
# Allow the plain X-Admin-Token header to authenticate (legacy mode).
# When false, only the hardened HMAC form `secret:ts:hmac` is accepted on
# /admin/* routes. Defaults true to preserve scripts (kill_switch.py etc.)
# during rollout; flip to false once every client uses HMAC tokens.
LEGACY_ADMIN_AUTH=true

# ---- Reverse-proxy IP trust ------------------------------------------------
# Comma-separated list of TCP peer IPs that may set X-Forwarded-For for
# rate-limit + audit-log attribution. Empty = trust nothing (ignore XFF
# entirely). In prod, put your Caddy/Nginx container's internal IP here.
TRUSTED_PROXIES=

# ---- Strategy selection ----------------------------------------------------
# Which SignalStrategy the signals service loads at boot. Implementations
# live under services/signals/strategies/. Default = smart_money_mirror.
SIGNAL_STRATEGY=smart_money_mirror

# Only used by the whale_follower strategy — single wallet to mirror.
# Ignored otherwise.
WHALE_FOLLOWER_ADDRESS=

# ---- Correlation tuning (optional — defaults in polybot/stats.py are fine) -
# Half-life for trade-recency decay (seconds). 900 = 15 min; aligns with
# the 15-min trade_ingest cadence so fresh trades weigh ~0.5-1.0.
# CORRELATION_HALF_LIFE_SECONDS=900
# Saturation constants for the wallet-count and notional sub-scores.
# CORRELATION_K_WALLETS=2.0
# CORRELATION_K_NOTIONAL=500
# Debounce: snappy when bursty, idle when quiet (seconds).
# CORRELATION_DEBOUNCE_BUSY_S=5
# CORRELATION_DEBOUNCE_IDLE_S=30
# CORRELATION_HEARTBEAT_S=60
