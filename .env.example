# =============================================================================
# Polybot — environment template. Copy to `.env` and fill in.
# =============================================================================

# ---- mode ------------------------------------------------------------------
TRADING_MODE=paper                         # paper | live
PAPER_STARTING_USDC=10000

# ---- Polymarket endpoints --------------------------------------------------
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_DATA_URL=https://data-api.polymarket.com
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws

# ---- Polygon RPC (use a real provider in prod — public RPC is rate-limited) -
POLYGON_RPC_URL=https://polygon-rpc.com
POLYGON_CHAIN_ID=137

# ---- Goldsky subgraph (replace with your hosted endpoint id) ---------------
GOLDSKY_SUBGRAPH_URL=https://api.goldsky.com/api/public/REPLACE/subgraphs/polymarket-positions/prod/gn

# ---- Live trading creds (LEAVE EMPTY for paper-mode) -----------------------
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=
POLYMARKET_SIGNATURE_TYPE=1                # 0=EOA  1=email/magic  2=browser

# ---- Database --------------------------------------------------------------
POSTGRES_USER=polybot
POSTGRES_PASSWORD=change_me
POSTGRES_DB=polybot
DATABASE_URL=postgresql+psycopg://polybot:change_me@postgres:5432/polybot

# ---- Redis ----------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# ---- API & dashboard -------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
DASHBOARD_API_URL=http://localhost:8000
ADMIN_TOKEN=please-generate-a-long-random-string
# CORS origins — comma-separated, NO wildcard. Use the dashboard's exact origin.
# In prod set this to https://your-domain.com or e.g. https://polybot.example.com
CORS_ORIGINS=http://localhost:3000

# ---- Risk limits (USDC) ----------------------------------------------------
MAX_POSITION_USDC=25
MAX_DAILY_LOSS_USDC=50
MAX_OPEN_POSITIONS=5
COOLDOWN_SECONDS_PER_MARKET=300

# ---- Wallet tracking -------------------------------------------------------
TOP_WALLETS_PER_CATEGORY=30
MIN_WIN_RATE=0.55
MIN_TRADE_COUNT_30D=20
CORRELATION_WINDOW_MINUTES=15
CORRELATION_MIN_WALLETS=3
CORRELATION_MIN_SCORE=0.65

# ---- Optional integrations -------------------------------------------------
SENTRY_DSN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- Off-host DB backup to GitHub (optional) -------------------------------
# Daily pg_dump gets pushed to a private GitHub repo, so a host disk failure
# can't lose both the live DB and the backup. Leave empty to disable.
#
# Setup:
#   1. Create a private repo on GitHub, e.g. yourname/polybot-backups
#   2. Generate a personal access token with `repo` scope on that repo
#   3. Fill the two vars below
#
# Rotation keeps the N most recent dumps in the repo (default 7).
GITHUB_BACKUP_TOKEN=
GITHUB_BACKUP_REPO=
GITHUB_BACKUP_KEEP=7
GITHUB_BACKUP_BRANCH=main

# ---- SIWE (Sign-In With Ethereum) auth ----
# Comma-separated lowercase Ethereum addresses that can sign in to the
# dashboard via wallet connection. Leave empty in paper mode for dev
# (any connected wallet can authenticate); REQUIRED in live mode.
# Example: ADMIN_WALLET_ADDRESSES=0xabc...,0xdef...
ADMIN_WALLET_ADDRESSES=
